# Network RPC URL (e.g., Anvil local node, Alchemy, Infura, etc.)
# Default is set to Anvil's default local RPC
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Private key for the deployer wallet
# WARNING: Never commit your real private key. Use a test wallet only.
PRIVATE_KEY=your_private_key_here

# Optional: Etherscan API Key for contract verification
ETHERSCAN_API_KEY=""

# Pinata IPFS API credentials (get from https://app.pinata.cloud)
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret
