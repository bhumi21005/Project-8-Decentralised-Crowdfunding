{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    { "src": "/api/upload", "dest": "/api/upload.js" },
    { "src": "/api/ipfs/(.+)", "dest": "/api/ipfs/[id].js?id=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
